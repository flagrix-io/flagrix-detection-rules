{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flagrix Detection Rules Schema",
  "description": "Schema for validating Flagrix YAML rule files after compilation to JSON",
  "type": "object",
  "required": ["version", "lastUpdated", "maliciousPackages", "yaraRules", "knownBadHashes"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Signature database version (e.g. 2025.01.26.001)",
      "pattern": "^\\d{4}\\.\\d{2}\\.\\d{2}\\.\\d{3}$"
    },
    "lastUpdated": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    },
    "maliciousPackages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "severity", "source"],
        "properties": {
          "name": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "source": { "type": "string" },
          "version": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "yaraRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "pattern", "description", "tags", "severity"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "name": { "type": "string" },
          "pattern": { "type": "string" },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
        },
        "additionalProperties": false
      }
    },
    "knownBadHashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sha256", "type", "source"],
        "properties": {
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "type": { "type": "string", "enum": ["pdf", "js", "binary", "archive"] },
          "malwareFamily": { "type": "string" },
          "source": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
